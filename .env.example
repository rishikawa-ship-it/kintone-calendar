# kintone 接続情報 (共通)
# 例: https://your-domain.cybozu.com
KINTONE_BASE_URL=

# プラグインアップロード用 (@kintone/plugin-uploader)
# kintone システム管理者の認証情報
# 注: パスワード認証のみサポート (API トークン非対応)
KINTONE_USERNAME=
KINTONE_PASSWORD=

# テストアプリセットアップ用 (scripts/setup-test-app/index.js)
# アプリ管理権限を持つ API トークン
KINTONE_API_TOKEN=
KINTONE_APP_ID=

# フィールドバリアント (datetime | date)
# 時間予定対応 → datetime / 終日のみ → date
KC_FIELDS_VARIANT=datetime
